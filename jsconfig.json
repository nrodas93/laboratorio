{
    "compilerOptions": {
        "module": "none",
        "target": "es6",
        "strict": false,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "jsx": "preserve",
        "lib": [
            "ES2015",
            "DOM"
        ],
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": false
    },
    "exclude": [
        "node_modules",
        "**/node_modules/*"
    ]
}